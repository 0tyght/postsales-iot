PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=postsales_iot

JWT_SECRET=replace_with_a_long_random_secret

# LINE Messaging API (ตั้งค่าจาก LINE Developers Console)
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_BOT_BASIC_ID=@your_line_basic_id
LINE_WEBHOOK_URL=https://your-public-url.example.com/linebot/webhook.php

# LINE OA สำหรับแจ้งเตือนทีมช่าง
# ใช้ Channel Access Token ของ OA ทีมช่าง และ Target ID ของกลุ่ม/ห้อง/ผู้ใช้ที่ต้องการส่งแจ้งเตือน
LINE_TECH_CHANNEL_ACCESS_TOKEN=your_technician_team_line_channel_access_token
LINE_TECH_TARGET_ID=your_line_group_or_user_id
